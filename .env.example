# NeuroHR AI - Environment Configuration (copy to .env)

# ======================
# JWT Authentication
# ======================
JWT_SECRET=123456789XYZ

# ======================
# MongoDB Atlas
# ======================
MONGODB_USER=vaishalisinghsln5_db_user
MONGODB_PASSWORD=your_db_password
MONGODB_DB=neurohr_ai
MONGODB_URL=mongodb+srv://vaishalisinghsln5_db_user:your_db_password@cluster0.hxsd3kk.mongodb.net/neurohr_ai?retryWrites=true&w=majority&appName=Cluster0

# ======================
# Redis
# ======================
REDIS_URL=redis://localhost:6379/0

# ======================
# LLM (Groq preferred for KB JD generation)
# ======================
GROQ_API_KEY=gsk-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_STRONG=llama-3.3-70b-versatile
# On-demand tier caps ~6000 tokens/request on 8b-instant; keep under budget when using that model
GROQ_REQUEST_TOKEN_BUDGET=5500
OPENAI_API_KEY=sk-your-openai-api-key

# ======================
# Organization & Knowledge Base
# ======================
ORG_NAME=XYZ
NEXT_PUBLIC_ORG_NAME=XYZ
KNOWLEDGEBASE_PATH=./knowledgebase
APP_URL=http://localhost:3000

# ======================
# Email (Gmail App Password — like great-harness-agent)
# ======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# HR mail identity (OAuth only — same token as Calendar; no app password)
SMTP_USER=vaishaleeaiml@gmail.com
HR_EMAIL=vaishaleeaiml@gmail.com

# Agent mail identity (OAuth only — credentials-1.json + agent-token.json)
AGENT_SMTP_USER=vaishaleeagent@gmail.com

# ======================
# Google Calendar + Meet (HR account — human panel Meet links)
# 1) HR OAuth JSON  → backend-express/credentials.json (existing)
# 2) Agent OAuth JSON → backend-express/credentials-1.json
# Agent token: node scripts/agent-google-auth.js (redirect: http://localhost:9091/oauth2callback)
# HR calendar: node scripts/google-calendar-auth.js (redirect: http://localhost:9090/oauth2callback)
# ======================
GOOGLE_CALENDAR_CREDENTIALS=./credentials.json
GOOGLE_CALENDAR_TOKEN=./token.json
GOOGLE_AGENT_CREDENTIALS=./credentials-1.json
GOOGLE_AGENT_TOKEN=./agent-token.json
CALENDAR_TIMEZONE=Asia/Kolkata

# ======================
# Service URLs
# ======================
ML_SERVICE_URL=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ML_URL=http://localhost:8001

# ======================
# File Upload
# ======================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
